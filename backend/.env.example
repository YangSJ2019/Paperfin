# LLM backend
#
# LLM_PROVIDER picks the wire protocol:
#   - "anthropic": Anthropic Messages API (POST /v1/messages).
#                  Works with Claude, Amazon Bedrock Claude, MiniMax's
#                  /anthropic endpoint, LiteLLM, and any other gateway
#                  that speaks this protocol.
#   - "openai":    OpenAI Chat Completions API (POST /v1/chat/completions).
#                  Works with OpenAI, DeepSeek, Zhipu, Groq, Ollama, vLLM,
#                  text-generation-webui, and almost every local inference
#                  server out there.
#
# The three LLM_* fields apply to whichever provider you pick. LLM_BASE_URL
# is optional: leave it blank to use the SDK default
# (api.anthropic.com for Anthropic, api.openai.com for OpenAI).
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=
LLM_MODEL=claude-opus-4-7

# --- Examples ---------------------------------------------------------------
#
# Claude (official Anthropic):
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-…
#   LLM_BASE_URL=
#   LLM_MODEL=claude-opus-4-7
#
# OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-…
#   LLM_MODEL=gpt-4o
#
# DeepSeek (OpenAI-shape):
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-…
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
# MiniMax (Anthropic-shape endpoint):
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-…
#   LLM_BASE_URL=https://api.minimaxi.com/anthropic
#   LLM_MODEL=MiniMax-M2.7
#
# Local Ollama server (OpenAI-shape):
#   LLM_PROVIDER=openai
#   LLM_API_KEY=ollama
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=qwen2.5
# ---------------------------------------------------------------------------

# Language for LLM-generated summaries and scoring rationales.
# Supported: "en" (default), "zh" (Simplified Chinese).
SUMMARY_LANGUAGE=en

# Optional: Semantic Scholar API key (apply at https://www.semanticscholar.org/product/api)
SEMANTIC_SCHOLAR_API_KEY=

# Runtime
DATA_DIR=./data
SCAN_INTERVAL_HOURS=6
LOG_LEVEL=INFO
