# LLM (Anthropic or Anthropic-compatible gateway)
#
# - Official Anthropic: leave ANTHROPIC_BASE_URL empty and set ANTHROPIC_MODEL
#   to a Claude model id (e.g. "claude-opus-4-7").
# - Third-party compatible gateway (e.g. MiniMax): set both.
ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-opus-4-7

# Language for LLM-generated summaries and scoring rationales.
# Supported: "en" (default), "zh" (Simplified Chinese).
SUMMARY_LANGUAGE=en

# Optional: Semantic Scholar API key (apply at https://www.semanticscholar.org/product/api)
SEMANTIC_SCHOLAR_API_KEY=

# Runtime
DATA_DIR=./data
SCAN_INTERVAL_HOURS=6
LOG_LEVEL=INFO
